# ======================================================================
# COSMOS-Q environment configuration
# Copy to .env and fill in your values.
# ======================================================================

# ------------------------------------------------------------------ #
# Qwen / DashScope API (required for live chat and text-embedding-v3)
# ------------------------------------------------------------------ #
COSMOS_QWEN_API_KEY=
COSMOS_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
COSMOS_QWEN_MODEL=qwen-plus

# Responses API (multi-turn, previous_response_id chaining)
COSMOS_RESPONSES_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Session cache: 10% token cost on cache hits, 5-min TTL refreshed on hit
COSMOS_ENABLE_SESSION_CACHE=true

# Thinking mode: enable for high-stakes reasoning (RTR, contradiction detection)
COSMOS_ENABLE_THINKING=false
COSMOS_THINKING_BUDGET_TOKENS=4096

# ------------------------------------------------------------------ #
# Embeddings — text-embedding-v3 (1024-dim) via DashScope
# ------------------------------------------------------------------ #
COSMOS_EMBEDDING_MODEL=text-embedding-v3
COSMOS_EMBEDDING_DIM=1024
COSMOS_DASHSCOPE_EMBEDDING_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Local fallback (used when QWEN_API_KEY is not set)
COSMOS_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
COSMOS_LOCAL_EMBEDDING_DIM=384

# ------------------------------------------------------------------ #
# Storage
# ------------------------------------------------------------------ #
# SQLite (default, for local development)
COSMOS_DB_PATH=cosmos_q.db

# ApsaraDB RDS for PostgreSQL + pgvector (production / Alibaba Cloud)
# Format: postgresql://user:password@host:5432/dbname
COSMOS_PG_DSN=

# ------------------------------------------------------------------ #
# MCP server (exposes COSMOS-Q as callable tools for Qwen agents)
# ------------------------------------------------------------------ #
COSMOS_MCP_HOST=0.0.0.0
COSMOS_MCP_PORT=8765

# ------------------------------------------------------------------ #
# Alibaba Cloud Function Compute (ASC background consolidation)
# ------------------------------------------------------------------ #
COSMOS_FC_SERVICE_NAME=cosmos-q-asc
COSMOS_FC_FUNCTION_NAME=consolidation-trigger
COSMOS_FC_REGION=cn-hangzhou

# ------------------------------------------------------------------ #
# Mechanism toggles (for ablation studies)
# ------------------------------------------------------------------ #
# COSMOS_ENABLE_RTR=true
# COSMOS_ENABLE_ASC=true
# COSMOS_ENABLE_IAAF=true
# COSMOS_ENABLE_UACP=true
