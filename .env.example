# ======================================================================
# COSMOS-Q environment configuration
# Copy to .env and fill in your values.
# ======================================================================

# ------------------------------------------------------------------ #
# Qwen / DashScope API
# Get your API key: https://docs.qwencloud.com/developer-guides/getting-started/first-api-call
# ------------------------------------------------------------------ #
COSMOS_QWEN_API_KEY=

# Chat Completions API (internal LLM calls, embeddings)
# International endpoint (Singapore). China: https://dashscope.aliyuncs.com/compatible-mode/v1
COSMOS_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Responses API (end-user chat, MCP tools, previous_response_id multi-turn)
# Different base_url — required for MCP tool support (MCP is not available
# via Chat Completions).
COSMOS_RESPONSES_API_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1

# Model selection:
#   qwen3.7-plus  — balanced performance/cost, hybrid thinking on by default
#   qwen3.7-max   — hardest reasoning and coding tasks
#   qwen3.6-flash — cost-efficient fast path
COSMOS_QWEN_MODEL=qwen3.7-plus

# Session cache — works with Responses API + previous_response_id.
# Hits cost 10% of input token price; 5-min TTL refreshed on hit.
# Requires ≥1024 tokens in prompt. Header: x-dashscope-session-cache: enable
COSMOS_ENABLE_SESSION_CACHE=true

# Thinking mode — toggle per operation type via extra_body={"enable_thinking": ...}
# Set to true to enable thinking by default for all calls (higher cost/latency).
# COSMOS-Q enables thinking selectively on high-stakes calls regardless.
COSMOS_ENABLE_THINKING=false
COSMOS_THINKING_BUDGET_TOKENS=4096

# ------------------------------------------------------------------ #
# Embeddings — text-embedding-v3 (1024-dim) via same base_url
# Docs: https://docs.qwencloud.com/api-reference/text-embedding/openai-embedding
# ------------------------------------------------------------------ #
COSMOS_EMBEDDING_MODEL=text-embedding-v3
COSMOS_EMBEDDING_DIM=1024

# Local fallback (used when QWEN_API_KEY is not set)
COSMOS_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
COSMOS_LOCAL_EMBEDDING_DIM=384

# ------------------------------------------------------------------ #
# Storage
# ------------------------------------------------------------------ #
# SQLite (default, for local development)
COSMOS_DB_PATH=cosmos_q.db

# ApsaraDB RDS for PostgreSQL + pgvector (production / Alibaba Cloud)
# Format: postgresql://user:password@host:5432/dbname
COSMOS_PG_DSN=

# ------------------------------------------------------------------ #
# MCP server (exposes COSMOS-Q as callable tools for Qwen agents)
# ------------------------------------------------------------------ #
COSMOS_MCP_HOST=0.0.0.0
COSMOS_MCP_PORT=8765

# ------------------------------------------------------------------ #
# Alibaba Cloud Function Compute (ASC background consolidation)
# ------------------------------------------------------------------ #
COSMOS_FC_SERVICE_NAME=cosmos-q-asc
COSMOS_FC_FUNCTION_NAME=consolidation-trigger
COSMOS_FC_REGION=cn-hangzhou

# ------------------------------------------------------------------ #
# Mechanism toggles (for ablation studies)
# ------------------------------------------------------------------ #
# COSMOS_ENABLE_RTR=true
# COSMOS_ENABLE_ASC=true
# COSMOS_ENABLE_IAAF=true
# COSMOS_ENABLE_UACP=true
