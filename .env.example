# Qwen / DashScope API (required for live chat)
COSMOS_QWEN_API_KEY=
COSMOS_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
COSMOS_QWEN_MODEL=qwen-plus

# Storage
COSMOS_DB_PATH=cosmos_q.db

# Mechanism toggles (for ablations)
# COSMOS_ENABLE_RTR=true
# COSMOS_ENABLE_ASC=true
# COSMOS_ENABLE_IAAF=true
# COSMOS_ENABLE_UACP=true
